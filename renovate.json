{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "matchDepTypes": ["requires-python"],
      "matchUpdateTypes": ["minor", "major"],
      "enabled": false
    },
    {
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dependencies"],
      "semanticCommitType": "fix"
    }
  ]
}
